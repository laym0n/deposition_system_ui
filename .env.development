PORT=3000
# In dev we call API through webpack-dev-server proxy to avoid CORS.
API_URL=/api
# Where proxy should forward to (real backend URL).
API_PROXY_TARGET=http://158.160.194.122/api
# Keycloak authority should stay real (no CORS issue for browser navigation/redirect).
# We proxy only token/userinfo/jwks endpoints via webpack-dev-server (see oidc.ts metadata override).
OIDC_AUTHORITY=https://158.160.194.122/keycloak/realms/deposition
OIDC_PROXY_TARGET=https://158.160.194.122
OIDC_CLIENT_ID=deposition-client
